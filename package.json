{
  "name": "@kartal-onur/hubai",
  "version": "0.1.1",
  "description": "HubAI — embeddable, framework-agnostic in-app AI assistant engine (Anthropic tool-use + SSE) with a headless React UI and a Supabase adapter. Context-scoped answers, in-app navigation, link replies.",
  "type": "module",
  "private": false,
  "license": "UNLICENSED",
  "author": "Globalmeta",
  "engines": {
    "node": ">=18.17.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kartal-onur/hubai.git"
  },
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./supabase": {
      "types": "./dist/supabase/index.d.ts",
      "import": "./dist/supabase/index.js"
    },
    "./styles.css": "./dist/react/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/react/styles.css dist/react/styles.css && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.80 <1",
    "@supabase/supabase-js": ">=2 <3",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5"
  }
}
